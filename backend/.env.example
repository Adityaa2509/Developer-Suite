APP_NAME=Sherlock
APP_VERSION=1.0.0
DEBUG=False

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_PRIMARY=gemini-2.0-flash
GEMINI_MODEL_FALLBACK=gemini-1.5-flash

